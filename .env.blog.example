# AI Agent Lab — Blog add-on env vars.
# Append these to your existing AI Agent Lab `docker/.env` (do NOT commit real secrets).

# Django/Wagtail secret key for the blog (required by mysite/settings/production.py).
# Generate one, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(64))"
WAGTAIL_SECRET_KEY=change-me-to-a-long-random-secret

# DOMAIN is already provided by the lab's .env (used by nginx + the blog vhost):
#   DOMAIN=example.com   ->  blog served at https://blog.example.com
